APP_ENV=production
APP_HOST=127.0.0.1
APP_PORT=8000

PUBLIC_BASE_URL=https://91.132.161.44:9443
PUBLIC_API_BASE_URL=
PUBLIC_WS_BASE_URL=
ALLOWED_ORIGINS=https://91.132.161.44:9443

DATABASE_URL=postgresql+asyncpg://app:change-me@postgres:5432/borofone_prod
POSTGRES_DB=borofone_prod
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me

REDIS_URL=redis://redis:6379/0
REDIS_DB=0

JWT_SECRET_KEY=change-me-to-a-long-random-string
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
ACCESS_TOKEN_EXPIRE_DAYS=30
REFRESH_TOKEN_EXPIRE_DAYS=30

HOST_DATA_ROOT=/var/lib/borofone/production
BACKUP_ROOT=/var/backups/borofone

# Always backed by host bind mount from ${HOST_DATA_ROOT}/uploads.
UPLOADS_DIR=/code/uploads
PAGES_DIR=pages
FAVICON_PATH=favicon.ico
MAIN_PAGE_PATH=main.html
LOGIN_PAGE_PATH=login.html
REGISTER_PAGE_PATH=register.html
# Leaderboard files are always backed by host bind mount from ${HOST_DATA_ROOT}/leaderboard.

MAX_AVATAR_BYTES=3145728
MAX_UPLOAD_FILE_SIZE=10485760

RADMIN_IP=91.132.161.44
SSL_HOST=0.0.0.0
SSL_PORT=9443
SSL_CERT_PATH=ssl/cert.pem
SSL_KEY_PATH=ssl/key.pem
SSL_PFX_PATH=ssl/voice.pfx
SSL_PFX_PASSWORD=1234

GIPHY_API_KEY=
