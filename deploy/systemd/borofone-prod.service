[Unit]
Description=Borofone Chat Production
After=network.target

[Service]
User=root
WorkingDirectory=/opt/borofone-chat-prod
EnvironmentFile=/opt/borofone-chat-prod/.env
ExecStart=/opt/borofone-chat-prod/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
