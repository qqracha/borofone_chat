DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=your-super-secret-key-change-me

# Radmin VPN IP address for HTTPS access
RADMIN_IP=your-radmin-vpn-ip-address

# Additional CORS origins (comma-separated)
# ALLOWED_ORIGINS=https://example.com,https://another.com

# Giphy API Key (optional, defaults to public beta key)
# Get your key at https://developers.giphy.com/dashboard/
# GIPHY_API_KEY=your-giphy-api-key